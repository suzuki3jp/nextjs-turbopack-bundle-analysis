{
  "name": "nextjs-turbopack-bundle-analysis",
  "version": "0.0.4",
  "packageManager": "pnpm@9.5.0",
  "description": "GitHub Action to analyze and compare Next.js Turbopack bundle sizes in PRs",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && node scripts/release.mjs"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "gzip-size": "^7.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.0.0"
  }
}
